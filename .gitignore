# Игнорировать все файлы
*

# Но отслеживать HTML файлы сайта
!*.html

# Отслеживать .gitignore
!.gitignore

# Игнорировать резервные копии
backup/

# Игнорировать Python файлы
*.py
*.pyc
__pycache__/

# Игнорировать текстовые отчеты
*.txt

# Игнорировать системные файлы
.DS_Store
Thumbs.db
desktop.ini

# Игнорировать временные файлы
*.tmp
*.bak
*.swp
*~

# Игнорировать логи
*.log
